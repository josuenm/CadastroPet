# ====================================================================
# .NET
# ====================================================================
# Arquivos de compilação e binários gerados pelo C#
[Bb]in/
[Oo]bj/

# Caches e propriedades do gerenciador de pacotes NuGet
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# Arquivos de log e relatórios de crash do .NET
*.log
*.crash

# ====================================================================
# React + Vite
# ====================================================================
# Pasta de dependências pesadas do Node (NUNCA deve ir para o Git)
node_modules/

# Pasta de build de produção gerada pelo Vite (npm run build)
dist/

# Caches locais do npm/yarn e arquivos de log de erro
.npm
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Arquivos de diagnóstico do TypeScript
*.tsbuildinfo

# ====================================================================
# IDEs
# ====================================================================
# Configurações de workspace do Cursor e VS Code
.vscode/

# Arquivos de preferências e cache do Visual Studio tradicional
.vs/
*.user
*.suo
*.userosscache
*.userprefs

# ====================================================================
# Segurança, Segredos e Variáveis de Ambiente
# ====================================================================
# Arquivos que guardam chaves de API e senhas locais do Vite
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Arquivos de configuração de produção ou locais do .NET com dados sensíveis
appsettings.Production.json
appsettings.Local.json

# ====================================================================
# Sistema Operacional
# ====================================================================
# Arquivos temporários do macOS e Windows
.DS_Store
Thumbs.db
